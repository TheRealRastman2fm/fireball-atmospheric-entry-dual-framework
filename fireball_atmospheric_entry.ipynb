import numpy as np
import pandas as pd
import matplotlib.pyplot as plt
from scipy.stats import pearsonr

# =========================
# LOAD DATA
# =========================
df = pd.read_csv("data/raw/cneos_fireball_2017_2024.csv")
df = df.dropna()

print("Number of events:", len(df))
print("Mean velocity (km/s):", df["velocity"].mean())
print("Mean altitude (km):", df["altitude"].mean())
print("Mean energy (J):", df["energy"].mean())

# =========================
# VELOCITY DISTRIBUTION
# =========================
plt.figure()
plt.hist(df["velocity"], bins=20)
plt.xlabel("Velocity (km/s)")
plt.ylabel("Frequency")
plt.title("Fireball Entry Velocity Distribution")
plt.show()

# =========================
# ALTITUDE DISTRIBUTION
# =========================
plt.figure()
plt.hist(df["altitude"], bins=20)
plt.xlabel("Altitude (km)")
plt.ylabel("Frequency")
plt.title("Peak Brightness Altitude Distribution")
plt.show()

# =========================
# KINETIC ENERGY
# =========================
df["kinetic_energy"] = 0.5 * (df["velocity"] * 1000)**2

print(df[["velocity", "kinetic_energy"]].head())

# =========================
# CORRELATION ANALYSIS
# =========================
r, p = pearsonr(df["energy"], df["kinetic_energy"])
print("\nPearson correlation (energy vs kinetic energy):", r)
print("p-value:", p)

# =========================
# ENERGY VS VELOCITY
# =========================
plt.figure()
plt.scatter(df["velocity"], df["energy"])
plt.xlabel("Velocity (km/s)")
plt.ylabel("Radiated Energy (J)")
plt.title("Fireball Energy vs Entry Velocity")
plt.show()

# =========================
# ATMOSPHERIC DENSITY MODEL
# =========================
def atmospheric_density(h, rho0=1.2, H=7.5):
    return rho0 * np.exp(-h / H)

h = np.linspace(0, 100, 200)

plt.figure()
plt.plot(h, atmospheric_density(h))
plt.xlabel("Altitude (km)")
plt.ylabel("Density (kg/m³)")
plt.title("Exponential Atmospheric Density Model")
plt.show()

# =========================
# SIMPLE TRAJECTORY MODEL
# =========================
def drag_acceleration(v, rho, Cd=1.0, A=1.0, m=1000):
    return -0.5 * Cd * rho * A * v**2 / m

v = 20000  # initial velocity (m/s)
dt = 0.05

altitudes = np.linspace(100, 20, 200)
velocities = []

for h in altitudes:
    rho = atmospheric_density(h)
    dv = drag_acceleration(v, rho)
    v += dv * dt
    velocities.append(v)

plt.figure()
plt.plot(altitudes, velocities)
plt.xlabel("Altitude (km)")
plt.ylabel("Velocity (m/s)")
plt.title("Atmospheric Entry Deceleration (Simplified Model)")
plt.gca().invert_xaxis()
plt.show()

# =========================
# ALTITUDE vs VELOCITY
# =========================
plt.figure()
plt.scatter(df["velocity"], df["altitude"])
plt.xlabel("Velocity (km/s)")
plt.ylabel("Peak Brightness Altitude (km)")
plt.title("Velocity vs Peak Brightness Altitude")
plt.show()

# =========================
# KEY PHYSICS SUMMARY
# =========================
print("\nKEY PHYSICS RELATION:")
print("Kinetic Energy: E = 1/2 m v^2")
print("=> Energy scales quadratically with velocity")
print("=> Explains strong fireball brightness variation")